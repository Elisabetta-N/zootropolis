generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   Int                 @id @default(autoincrement())
  nome                 String
  email                String              @unique
  password             String
  role                 String              @default("user")
  citta                String              @default("Bari")
  avatar               String?
  documentStatus       String              @default("pending")
  paymentMethod        String              @default("Visa •••• 4242")
  paymentBrand         String              @default("visa")
  createdAt            DateTime            @default(now())
  notifications        Boolean             @default(true)
  suspended            Boolean             @default(false)
  bookings             Booking[]
  messages             SupportMessage[]
  maintenanceReports   UrbanMaintenance[]
}

model Vehicle {
  id           Int       @id @default(autoincrement())
  type         String
  lat          Float
  lng          Float
  batteryLevel Int       @default(100)
  status       String    @default("available")
  hasFault     Boolean   @default(false)
  faultNote    String?
  blocked      Boolean   @default(false)
  stolen       Boolean   @default(false)
  stolenAt     DateTime?
  bookings     Booking[]
}

model Booking {
  id              Int       @id @default(autoincrement())
  userId          Int
  vehicleId       Int
  status          String    @default("active")
  destination     String?
  destLat         Float?
  destLng         Float?
  distance        Float?
  cost            Float?
  durationSeconds Float?
  paid            Boolean   @default(false)
  createdAt       DateTime  @default(now())
  endedAt         DateTime?
  user            User      @relation(fields: [userId], references: [id])
  vehicle         Vehicle   @relation(fields: [vehicleId], references: [id])
}

model SupportMessage {
  id        Int      @id @default(autoincrement())
  userId    Int
  message   String
  isStaff   Boolean  @default(false)
  vehicleId Int?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model UrbanMaintenance {
  id           Int      @id @default(autoincrement())
  title        String
  description  String
  lat          Float?
  lng          Float?
  status       String   @default("open")
  reportedById Int
  createdAt    DateTime @default(now())
  reportedBy   User     @relation(fields: [reportedById], references: [id])
}

model IncentivePoint {
  id        Int      @id @default(autoincrement())
  lat       Float
  lng       Float
  discount  Int      @default(10)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model ProhibitedArea {
  id        Int      @id @default(autoincrement())
  name      String
  lat       Float
  lng       Float
  radius    Float    @default(200) // in meters
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}
